# ─────────────────────────────────────────────────────
# PETOVIX — Variables de entorno del backend
# Copia este archivo como ".env" y rellena los valores
# NUNCA subas el archivo .env real a Git
# ─────────────────────────────────────────────────────

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=korium43
DB_USER=root
DB_PASSWORD=tu_password_aqui

# JWT — usa una cadena larga y aleatoria (mínimo 32 caracteres)
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=44a580585e08a911889d7c0ccd2988bf1adfe06a8563fa95d3d3d770ba399095

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# URL del frontend (requerido en producción para CORS)
# Ejemplo: https://petovix.com
FRONTEND_URL=http://localhost:5173
